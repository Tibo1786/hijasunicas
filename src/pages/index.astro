---
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hijas Únicas Editorial — Próximamente</title>
    <meta name="description" content="Hijas Únicas Editorial — Todo empieza con una historia y la nuestra está a punto de empezar." />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #f5efe0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Lora', serif;
        color: #1a2a5e;
      }

      .container {
        text-align: center;
        padding: 2rem;
        max-width: 640px;
      }

      .logo {
        width: 560px;
        max-width: 90vw;
        height: auto;
        margin: 0 auto 3rem;
        display: block;
      }

      .divider {
        width: 60px;
        height: 2px;
        background-color: #c4a35a;
        margin: 0 auto 2.5rem;
      }

      .message {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        line-height: 1.6;
        color: #1a2a5e;
        margin-bottom: 1rem;
        font-weight: 400;
      }

      .proximamente {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #c4a35a;
        font-weight: 600;
      }

      @media (max-width: 480px) {
        .message {
          font-size: 1.15rem;
        }
        .logo {
          width: 440px;
          margin-bottom: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <img
        src={`${baseUrl}ConstructionLogo.jpeg`}
        alt="Hijas Únicas Editorial"
        class="logo"
      />
      <div class="divider"></div>
      <p class="message">
        Todo empieza con una historia<br />y la nuestra está a punto de empezar.
      </p>
      <p class="proximamente">Próximamente</p>
    </div>
  </body>
</html>
