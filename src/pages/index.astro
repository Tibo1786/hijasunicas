---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Hijas Únicas Editorial — Próximamente"
  description="Hijas Únicas Editorial — Todo empieza con una historia y la nuestra está a punto de empezar."
>
  <section class="relative py-20 sm:py-28 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute inset-0 scale-105 bg-cover bg-center blur-sm opacity-60"
        style={`background-image: url(${baseUrl}hero-bg.jpg)`}
      >
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-cream/60 via-cream/40 to-cream/70"></div>
    </div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-heading text-navy text-6xl sm:text-7xl lg:text-8xl tracking-widest mb-4">
        hijas únicas
      </p>
      <p class="font-heading text-gold text-lg sm:text-xl tracking-[0.3em] uppercase mb-10">
        editorial
      </p>
      <div class="w-16 h-0.5 bg-gold mx-auto mb-8"></div>
      <p class="font-heading text-navy text-xl sm:text-2xl leading-relaxed mb-2">
        Todo empieza con una historia
      </p>
      <p class="font-heading text-navy text-xl sm:text-2xl leading-relaxed mb-6">
        y la nuestra está a punto de empezar.
      </p>
      <p class="font-heading text-gold text-sm tracking-[0.3em] uppercase font-semibold mb-12">
        Próximamente
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${baseUrl}nosotras/`}
          class="inline-block bg-navy text-cream px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy-light transition-colors"
        >
          Conócenos
        </a>
        <a
          href={`${baseUrl}contacto/`}
          class="inline-block border-2 border-navy text-navy px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy hover:text-cream transition-colors"
        >
          Escríbenos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
