---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Página no encontrada — Hijas Únicas Editorial">
  <section class="py-24 sm:py-32 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-navy text-6xl sm:text-8xl mb-4">404</h1>
      <p class="text-text-light text-lg mb-8">
        Esta página no existe o ha sido movida.
      </p>
      <a
        href={baseUrl}
        class="inline-block bg-navy text-cream px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy-light transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
