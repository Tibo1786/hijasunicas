---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout title="Contacto — Hijas Únicas Editorial" description="Ponte en contacto con Hijas Únicas Editorial.">
  <section class="py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Contacto"
        subtitle="Nos encantaría saber de ti."
      />

      <div class="max-w-xl mx-auto text-center space-y-10">
        <div>
          <h3 class="font-heading text-navy text-xl mb-3">Escríbenos</h3>
          <a
            href="mailto:clara@hijasunicas.es"
            class="inline-block bg-navy text-cream px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy-light transition-colors"
          >
            clara@hijasunicas.es
          </a>
        </div>

        <div>
          <h3 class="font-heading text-navy text-xl mb-3">Síguenos</h3>
          <a
            href="https://instagram.com/hijasunicas"
            target="_blank"
            rel="noopener"
            class="text-text-light hover:text-gold transition-colors"
          >
            Instagram
          </a>
        </div>

        <div>
          <h3 class="font-heading text-navy text-xl mb-3">Manuscritos</h3>
          <p class="text-text-light text-sm leading-relaxed">
            Si quieres enviarnos tu manuscrito, escríbenos directamente incluyendo una
            breve sinopsis y los tres primeros capítulos. Te responderemos lo antes posible.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
