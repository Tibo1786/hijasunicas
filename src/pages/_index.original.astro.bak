---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BookCard from '../components/BookCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { PLACEHOLDER_BOOKS, PLACEHOLDER_POSTS } from '../lib/sanity';

const featuredBooks = PLACEHOLDER_BOOKS.filter((b) => b.featured).slice(0, 3);
const latestPost = PLACEHOLDER_POSTS[PLACEHOLDER_POSTS.length - 1];
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Hijas Únicas Editorial">
  <Hero />

  <!-- Featured Books -->
  <section class="py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Nuestros libros"
        subtitle="Historias que merecen ser contadas y leídas."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredBooks.map((book) => (
          <BookCard
            title={book.title}
            author={book.author}
            coverUrl={book.coverUrl}
            slug={book.slug}
          />
        ))}
      </div>
      <div class="text-center mt-12">
        <a
          href={`${baseUrl}catalogo/`}
          class="inline-block border-2 border-navy text-navy px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy hover:text-cream transition-colors"
        >
          Ver todo el catálogo
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Blog Post -->
  {latestPost && (
    <section class="py-16 sm:py-20 bg-white/50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="Últimas noticias"
          subtitle="Novedades, entrevistas y más desde la editorial."
        />
        <div class="max-w-xl mx-auto">
          <BlogCard
            title={latestPost.title}
            excerpt={latestPost.excerpt}
            date={latestPost.publishDate}
            coverUrl={latestPost.coverUrl}
            slug={latestPost.slug}
          />
        </div>
        <div class="text-center mt-12">
          <a
            href={`${baseUrl}blog/`}
            class="inline-block border-2 border-navy text-navy px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy hover:text-cream transition-colors"
          >
            Leer más
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-navy text-3xl sm:text-4xl mb-4">
        ¿Tienes una historia que contar?
      </h2>
      <p class="text-text-light mb-8">
        En Hijas Únicas buscamos voces auténticas con historias que merezcan ser escuchadas.
      </p>
      <a
        href={`${baseUrl}contacto/`}
        class="inline-block bg-gold text-white px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-gold-light transition-colors"
      >
        Escríbenos
      </a>
    </div>
  </section>
</BaseLayout>
