---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <h2 class="font-heading text-navy text-3xl sm:text-4xl">{title}</h2>
  {subtitle && (
    <p class="text-text-light mt-3 max-w-2xl mx-auto">{subtitle}</p>
  )}
  <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
</div>
