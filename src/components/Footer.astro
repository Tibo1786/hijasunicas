---
const baseUrl = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="bg-navy text-cream/80">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Links -->
      <div>
        <h3 class="font-heading text-cream text-lg mb-4">Navegar</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${baseUrl}contacto/`} class="hover:text-gold transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-cream text-lg mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="mailto:info@hijasunicas.es" class="hover:text-gold transition-colors">
              info@hijasunicas.es
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-cream/20 mt-8 pt-8 text-center text-xs text-cream/50">
      <p>&copy; {year} Hijas Únicas Editorial. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
