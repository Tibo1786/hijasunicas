---
interface Props {
  title: string;
  author: string;
  coverUrl: string;
  slug: string;
  synopsis?: string;
}

const baseUrl = import.meta.env.BASE_URL;
const { title, author, coverUrl, slug, synopsis } = Astro.props;
---

<article class="group">
  <a href={`${baseUrl}catalogo/${slug}/`} class="block">
    <div class="aspect-[2/3] overflow-hidden bg-cream-dark mb-4">
      <img
        src={coverUrl}
        alt={`Portada de ${title}`}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
    <h3 class="font-heading text-navy text-lg group-hover:text-gold transition-colors">
      {title}
    </h3>
    <p class="text-text-light text-sm mt-1">{author}</p>
    {synopsis && (
      <p class="text-text-light text-sm mt-2 line-clamp-2">{synopsis}</p>
    )}
  </a>
</article>
