---
const baseUrl = import.meta.env.BASE_URL;
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <img
      src={`${baseUrl}logo.png`}
      alt="Hijas Únicas Editorial"
      class="mx-auto h-28 sm:h-36 lg:h-44 w-auto mb-8"
    />
    <p class="font-heading text-navy text-xl sm:text-2xl lg:text-3xl leading-relaxed mb-8">
      Historias que importan, contadas por voces únicas.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`${baseUrl}catalogo/`}
        class="inline-block bg-navy text-cream px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy-light transition-colors"
      >
        Descubrir catálogo
      </a>
      <a
        href={`${baseUrl}nosotras/`}
        class="inline-block border-2 border-navy text-navy px-8 py-3 font-heading text-sm tracking-widest uppercase hover:bg-navy hover:text-cream transition-colors"
      >
        Conócenos
      </a>
    </div>
  </div>
</section>
